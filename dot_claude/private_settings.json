{
  "env": {
    "COMPACT_PLUS_FALLBACK_BACKEND": "bash \"$HOME/.claude/compact-plus-backend/backend-codex-mini.sh\"",
    "COMPACT_PLUS_TRANSCRIPT_MODE": "tail",
    "COMPACT_PLUS_TRANSCRIPT_TAIL_TURNS": "60",
    "COMPACT_PLUS_TRANSCRIPT_TAIL_KB": "120"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(git -C * *)",
      "Bash(chezmoi apply *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git checkout --*)"
    ],
    "ask": [
      "Bash(claude -p:*)",
      "Bash(claude --print:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet[1m]",
  "skillOverrides": {
    "book-to-skill": "off",
    "report-skills": "off"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-private-sync.sh pull"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/yagu001/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-private-sync.sh push"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/chezmoi-auto-apply.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/herdr-plan-preview.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/userpromptsubmit-compact-prep-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/memory_recall.py",
            "timeout": 5,
            "statusMessage": "関連メモリを検索中..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": false,
    "superpowers@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "compact-plus@compact-plus-local": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "compact-plus-local": {
      "source": {
        "source": "github",
        "repo": "u-ichi/compact-plus"
      }
    }
  },
  "effortLevel": "high",
  "askUserQuestionTimeout": "never",
  "tui": "fullscreen",
  "switchModelsOnFlag": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipWorkflowUsageWarning": false
}

#!/bin/sh
set -u

{{- if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") (ne (env "REMOTE_CONTAINERS") "true") }}
source_settings="{{ .chezmoi.sourceDir }}/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"

if [ ! -f "$source_settings" ]; then
  echo "warning: Windows Terminal source settings not found: $source_settings" >&2
  exit 0
fi

if ! command -v powershell.exe >/dev/null 2>&1; then
  echo "warning: powershell.exe not found; skipped Windows Terminal settings install" >&2
  exit 0
fi

windows_local_appdata=$(powershell.exe -NoProfile -Command '[Environment]::GetFolderPath("LocalApplicationData")' 2>/dev/null | tr -d '\r' | tail -n 1)
if [ -z "$windows_local_appdata" ]; then
  echo "warning: could not resolve Windows LocalAppData; skipped Windows Terminal settings install" >&2
  exit 0
fi

windows_local_appdata_wsl=$(wslpath -u "$windows_local_appdata" 2>/dev/null || true)
if [ -z "$windows_local_appdata_wsl" ]; then
  echo "warning: could not convert Windows LocalAppData path: $windows_local_appdata" >&2
  exit 0
fi

target_settings="$windows_local_appdata_wsl/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"
mkdir -p "$(dirname "$target_settings")"

if ! cp -f "$source_settings" "$target_settings"; then
  echo "warning: could not install Windows Terminal settings to: $target_settings" >&2
  exit 0
fi
{{- end }}

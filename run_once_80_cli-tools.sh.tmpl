#!/bin/bash
set -eu

{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
{{     if ne (env "REMOTE_CONTAINERS") "true" }}

# 非インタラクティブシェルでは .profile が読まれないため brew を PATH に追加
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

export HOMEBREW_NO_AUTO_UPDATE=1

# CLI ツールを Brewfile で一括インストール（冪等・導入済みはスキップ）。
# ツールを追加するときはこのリストに 1 行足すだけでよい。
# pyenv / pyenv-virtualenv は run_once_40、nvm は run_once_50 で管理するためここには含めない。
echo "CLIツール一括インストール開始（brew bundle）"
brew bundle install --no-upgrade --file=- <<'BREWFILE'
brew "aicommit2"      # AI でコミットメッセージ生成
brew "bitwarden-cli"  # パスワードマネージャ CLI
brew "fzf"            # ファジーファインダー
brew "gh"             # GitHub CLI
brew "ghq"            # リモートリポジトリ管理
brew "git-delta"      # chezmoi/git の diff 表示（構文ハイライト付き）
brew "herdr"          # AI エージェント向けターミナルマルチプレクサ
brew "jq"             # JSON プロセッサ（hook 群が依存）
brew "lazygit"        # git TUI
brew "pandoc"         # マークアップ変換
brew "peco"           # インタラクティブフィルタ
brew "poppler"        # PDF レンダリング（pdftotext 等）
brew "rtk"            # LLM トークン削減 CLI プロキシ
brew "tesseract"      # OCR エンジン
brew "tesseract-lang" # Tesseract 追加言語データ
BREWFILE
echo "CLIツール一括インストール完了"

{{     end }}
{{   end }}
{{ end }}

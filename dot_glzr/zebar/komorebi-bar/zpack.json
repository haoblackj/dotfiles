{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.0.0/resources/zpack-schema.json",
  "name": "komorebi-bar",
  "version": "0.0.0",
  "description": "Horizon Dark配色のタイル型WM用ステータスバー(自宅Komorebi=with-komorebi/職場GlazeWM=with-glazewm、公式starterをベースにカスタマイズ)",
  "tags": [
    "topbar"
  ],
  "previewImages": [
    "./resources/preview-image-1.png"
  ],
  "repositoryUrl": "",
  "widgets": [
    {
      "name": "with-komorebi",
      "htmlPath": "./with-komorebi.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": true,
      "transparent": true,
      "includeFiles": [
        "*.html",
        "*.css"
      ],
      "caching": {
        "defaultDuration": 0,
        "rules": []
      },
      "privileges": {
        "shellCommands": [
          {
            "program": "komorebic.exe",
            "argsRegex": "^focus-named-workspace .+$"
          }
        ]
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "40px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    },
    {
      "name": "with-glazewm",
      "htmlPath": "./with-glazewm.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": true,
      "transparent": true,
      "includeFiles": [
        "*.html",
        "*.css"
      ],
      "caching": {
        "defaultDuration": 0,
        "rules": []
      },
      "privileges": {
        "shellCommands": []
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "40px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    }
  ]
}

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

if [[ ! -f $HOME/.zi/bin/zi.zsh ]]; then
  print -P "%F{33}▓▒░ %F{160}Installing (%F{33}z-shell/zi%F{160})…%f"
  command mkdir -p "$HOME/.zi" && command chmod go-rwX "$HOME/.zi"
  command git clone -q --depth=1 --branch "main" https://github.com/z-shell/zi "$HOME/.zi/bin" && \
    print -P "%F{33}▓▒░ %F{34}Installation successful.%f%b" || \
    print -P "%F{160}▓▒░ The clone has failed.%f%b"
fi
source "$HOME/.zi/bin/zi.zsh"
autoload -Uz _zi
(( ${+_comps} )) && _comps[zi]=_zi
# examples here -> https://wiki.zshell.dev/ecosystem/category/-annexes
zicompinit # <- https://wiki.zshell.dev/docs/guides/commands

zinit ice depth=1; zinit light romkatv/powerlevel10k

source ~/zsh/plugins.zsh
source ~/zsh/config.zsh
source ~/zsh/alias.zsh
{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
{{     if ne (env "REMOTE_CONTAINERS") "true" }}
source ~/zsh/wsl_only.zsh
{{     end }}
{{   end }}
{{ end }}

# To customize prompt, run `p10k configure` or edit .../zsh/p10k.zsh.
[[ ! -f ~/zsh/p10k.zsh ]] || source ~/zsh/p10k.zsh

# Homebrew 環境変数の設定（ユーザー or システムインストール対応）
if [ -d "$HOME/.linuxbrew" ]; then
  eval "$($HOME/.linuxbrew/bin/brew shellenv)"
elif [ -d "/home/linuxbrew/.linuxbrew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

. "/home/yagu001/.deno/env"

# pyenv 設定
export PYENV_ROOT="$(brew --prefix pyenv)"  # or "$HOME/.pyenv" if not using Homebrew
export PATH="$PYENV_ROOT/bin:$PATH"

# Pythonビルド用（Homebrewライブラリ参照）
export LDFLAGS="-L$(brew --prefix openssl)/lib -L$(brew --prefix zlib)/lib"
export CPPFLAGS="-I$(brew --prefix openssl)/include -I$(brew --prefix zlib)/include"

# 初期化
eval "$(pyenv init - zsh)"
eval "$(pyenv virtualenv-init -)"

# その他設定
unsetopt nomatch

# chezmoi drift check (once per login session)
if [[ -z "$_CHEZMOI_CHECKED" ]] && command -v chezmoi &>/dev/null; then
  _CHEZMOI_CHECKED=1
  local _chezmoi_status
  _chezmoi_status=$(chezmoi status 2>/dev/null)
  if [[ -n "$_chezmoi_status" ]]; then
    print -P "%F{yellow}⚠  chezmoi: managed files have drifted.%f"
    print -P "%F{yellow}$(echo "$_chezmoi_status" | awk '{print "   " $0}')%f"
    print -P "%F{yellow}   - 差分確認:            chezmoi diff%f"
    local _chezmoi_files
    _chezmoi_files=$(echo "$_chezmoi_status" | awk '{print $NF}' | tr '\n' ' ')
    print -P "%F{yellow}   - ホームの変更を取込む: chezmoi re-add ${_chezmoi_files}%f"
    print -P "%F{yellow}   - ソースをホームに適用: chezmoi apply%f"
  fi
fi